# Node Environment
NODE_ENV=development
PORT=5000

# Database Configuration
DATABASE_TYPE=sqlite
DATABASE_URL=./data/whatsapp.db

# For PostgreSQL (uncomment to use)
# DATABASE_TYPE=postgres
# DATABASE_HOST=localhost
# DATABASE_PORT=5432
# DATABASE_USER=whatsapp
# DATABASE_PASSWORD=whatsapp123
# DATABASE_NAME=whatsapp_bot

# JWT Configuration
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key
JWT_REFRESH_EXPIRE=30d

# Socket.IO Configuration
SOCKET_IO_CORS_ORIGIN=http://localhost:5173,http://localhost:3000
SOCKET_IO_CORS_CREDENTIALS=true

# Admin Configuration
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin123
ADMIN_USERNAME=admin

# Features
ENABLE_ANALYTICS=true
ENABLE_LOGS=true
ENABLE_ANTI_SPAM=true
ENABLE_ANTI_LINK=true

# Rate Limiting
RATE_LIMIT_WINDOW_MS=15000
RATE_LIMIT_MAX_REQUESTS=100

# Baileys Configuration
BAILEYS_PAIRING_CODE_ENABLED=true
BAILEYS_SESSION_DIR=./sessions
BAILEYS_LOGS_LEVEL=error

# Session Configuration
SESSION_SAVE_INTERVAL=5000
SESSION_EXPIRY_DAYS=30

# Broadcasting
BROADCAST_MAX_RECIPIENTS=500
BROADCAST_DELAY_MS=500

# Scheduled Messages
SCHEDULED_MESSAGE_CHECK_INTERVAL=60000

# Logging
LOG_LEVEL=info
LOG_DIR=./logs
